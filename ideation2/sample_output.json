  "elasticsearch_query_examples": {
    "keyword_lookup": {
      "_comment": "O(1) exact lookup — user says 'heart attack' → resolve to canonical name",
      "GET": "neurohealth_health_kwmap/_doc/heart attack"
    },
    "symptom_based_search": {
      "_comment": "User reports symptoms → find matching conditions (core conversational use case)",
      "POST": "neurohealth_symptom_map/_search",
      "body": {
        "query": {
          "bool": {
            "should": [
              {"terms": {"symptom.keyword": ["headache", "fever", "stiff neck"], "boost": 3.0}},
              {"match": {"symptom": {"query": "headache, fever, stiff neck", "boost": 1.5}}}
            ]
          }
        },
        "knn": {
          "field": "embedding",
          "query_vector": ["<768-dim vector of symptom query>"],
          "k": 10,
          "num_candidates": 100
        },
        "rank": {"_comment": "RRF removed — basic license uses additive BM25+KNN scoring"}
      }
    },
    "hybrid_health_search": {
      "_comment": "Natural language query — 'i have a bad headache and feel nauseous'",
      "POST": "neurohealth_health_topics/_search",
      "body": {
        "query": {
          "bool": {
            "should": [
              {"term": {"topic_name.keyword": {"value": "Migraine", "boost": 5.0}}},
              {"multi_match": {
                "query": "bad headache feel nauseous",
                "fields": ["topic_name^3", "also_called^2.5", "symptoms^2.5", "summary"],
                "fuzziness": "AUTO"
              }},
              {"match": {"symptoms": {"query": "headache nausea", "analyzer": "health_analyzer", "boost": 2.0}}}
            ]
          }
        },
        "knn": {
          "field": "embedding",
          "query_vector": ["<768-dim vector>"],
          "k": 5,
          "num_candidates": 75
        },
        "rank": {"_comment": "RRF removed — basic license uses additive BM25+KNN scoring"}
      }
    },
    "filter_by_type_and_system": {
      "_comment": "Find all conditions in the Nervous System",
      "POST": "neurohealth_health_topics/_search",
      "body": {
        "query": {
          "bool": {
            "filter": [
              {"term": {"topic_type": "condition"}},
              {"term": {"body_systems": "Nervous System"}}
            ]
          }
        },
        "size": 50
      }
    },
    "autocomplete": {
      "_comment": "Type-ahead as user types",
      "POST": "neurohealth_health_topics/_search",
      "body": {
        "suggest": {
          "topic_suggest": {
            "prefix": "diab",
            "completion": {"field": "topic_name.suggest", "size": 5}
          }
        }
      }
    }
  }
